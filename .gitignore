# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
#
# IMPORTANT — DO NOT ignore .env files. They MUST be committed for the
# Emergent Kubernetes deployment pipeline to pick them up. Production secret
# overrides happen in the Emergent deployment UI's Secrets panel, NOT here.
#
# If you see `-e\n# Environment and credential files\n.env\n.env.*\n*.env`
# blocks appended at the bottom of this file again — a platform hook re-added
# them. Re-rewrite this file from scratch (iter66 history shows this has
# happened 3 times now).

# IDE and editors
.idea/
.vscode/

# Dependencies
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# Production builds
/build
dist/
dist

# Credentials / secrets — do NOT blanket-block *.env (see header)
credentials.json
*.pem
*.key
.credentials
*token.json*
*credentials.json*

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# System files
.DS_Store

# Python
__pycache__/
*.pyc
venv/
.venv/

# Development tools
chainlit.md
.chainlit
.ipynb_checkpoints/
.ac

# Deployment
.vercel

# Data and databases
agenthub/agents/youtube/db

# Archive files and large assets
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Build caches
.cache/

# Test credentials — read by the testing subagent only
memory/test_credentials.md
frontend/node_modules/.cache/default-development/70.pack
frontend/node_modules/.cache/default-development/2.pack
frontend/node_modules/.cache/default-development/19.pack
frontend/node_modules/.cache/default-development/5.pack
frontend/node_modules/.cache/default-development/5.pack
frontend/node_modules/.cache/default-development/9.pack
frontend/node_modules/.cache/default-development/13.pack
